-- PING · migration 0007_client_portal
-- Área do Cliente com login próprio, separado do login da equipe.
--
-- Por que não é Supabase Auth: o cliente só tem nome e telefone (coletados
-- no agendamento, ver createAppointment) — não tem e-mail cadastrado, então
-- login por magic link não serve. Login por SMS/OTP exigiria contratar um
-- provedor à parte (Twilio etc.), que este projeto ainda não tem. A saída
-- mais simples e sem depender de nada externo: senha numérica de 4 dígitos
-- por telefone, com sessão própria guardada aqui — não em auth.users.

alter table clients add column if not exists pin_hash text;
alter table clients add column if not exists pin_set_at timestamptz;

create table if not exists client_sessions (
  id uuid primary key default uuid_generate_v4(),
  client_id uuid not null references clients(id) on delete cascade,
  token_hash text not null unique,
  expires_at timestamptz not null,
  created_at timestamptz not null default now()
);

create index if not exists client_sessions_token_hash_idx on client_sessions (token_hash);
create index if not exists client_sessions_client_id_idx on client_sessions (client_id);

-- RLS fica ligada, como em toda tabela deste projeto — mas de propósito
-- SEM nenhuma policy. Ninguém deveria conseguir ler ou escrever aqui com a
-- chave anônima; só o service role acessa (usado exclusivamente dentro de
-- Server Actions, nunca enviado ao navegador — ver lib/supabase/serviceRole.ts).
-- Sem policy = acesso negado por padrão pra anon/authenticated, que é
-- exatamente o comportamento que essa tabela precisa.
alter table client_sessions enable row level security;
